@model AzureCosmosTodoApp.Models.TodoItem

<h2>Edit Todo</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div>
        <label>Title</label>
        <input asp-for="Title" />
    </div>

    <div>
        <label>
            <input asp-for="IsCompleted" />
            Completed
        </label>
    </div>

    <button type="submit">Save</button>
</form>

<a asp-action="Index">Back</a>